generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
}

enum OwnershipType {
  OWNED
  RENTED
  LEASED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum FuelType {
  DIESEL
  GASOLINE
  ELECTRIC
  HYBRID
  LPG
  CNG
}

enum MileageSource {
  MANUAL
  REFUEL
  MAINTENANCE
  TRIP
}

enum TripStatus {
  OPEN
  COMPLETED
  ABANDONED
}

enum TripAnomalyType {
  LONG_DURATION
  EXCESSIVE_DISTANCE
  HIGH_AVERAGE_SPEED
  KM_INVARIATO
  MANUAL
}

enum TripAnomalyStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

enum MaintenanceType {
  TAGLIANDO
  REVISIONE
  RIPARAZIONE
  CAMBIO_GOMME
  ALTRO
}

enum DeadlineType {
  TAGLIANDO
  REVISIONE
  ASSICURAZIONE
  BOLLO
  REVISIONE_TACHIGRAFO
  ALTRO
}

enum DocumentType {
  CONTRATTO_NOLEGGIO
  ASSICURAZIONE
  LIBRETTO
  CARTA_CIRCOLAZIONE
  ALTRO
}

enum VehiclePhotoTemplate {
  FRONTE
  RETRO
  LATERALE_SX
  LATERALE_DX
  CRUSCOTTO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(DRIVER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedVehicles         Vehicle[]
  mileageReadings          MileageReading[]
  refuelings               Refueling[]
  maintenanceInterventions MaintenanceIntervention[]
  uploadedDocuments        Document[]
  uploadedVehiclePhotos    VehiclePhoto[]
  plannedMaintenances      PlannedMaintenance[]
  trips                    Trip[]
  createdTripAnomalies     TripAnomaly[]             @relation("TripAnomalyCreatedBy")
  resolvedTripAnomalies    TripAnomaly[]             @relation("TripAnomalyResolvedBy")
}

model Vehicle {
  id               String        @id @default(cuid())
  plate            String        @unique
  brand            String
  model            String
  year             Int
  vin              String?
  fuelType         FuelType
  ownershipType              OwnershipType
  status                     VehicleStatus @default(ACTIVE)
  registrationDate           DateTime?
  maintenanceIntervalMonths  Int?          @default(12)
  maintenanceIntervalKm      Int?
  assignedDriverId           String?
  assignedDriver             User?         @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  notes                      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  mileageReadings          MileageReading[]
  refuelings               Refueling[]
  maintenanceInterventions MaintenanceIntervention[]
  deadlines                Deadline[]
  documents                Document[]
  plannedMaintenances      PlannedMaintenance[]
  trips                    Trip[]
  photos                   VehiclePhoto[]

  @@index([plate])
  @@index([status])
  @@index([assignedDriverId])
}

model MileageReading {
  id               String        @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  recordedByUserId String
  recordedBy       User          @relation(fields: [recordedByUserId], references: [id])
  km               Int
  date             DateTime
  source           MileageSource
  notes            String?
  createdAt        DateTime      @default(now())

  @@index([vehicleId, date])
  @@index([vehicleId, km])
}

model Refueling {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  km        Int
  liters    Decimal  @db.Decimal(10, 2)
  costEur   Decimal  @db.Decimal(10, 2)
  fuelType  FuelType
  fullTank  Boolean  @default(true)
  station   String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([vehicleId, date])
}

model MaintenanceIntervention {
  id          String          @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  sourceTripAnomalyId String?
  sourceTripAnomaly   TripAnomaly? @relation("TripAnomalyMaintenanceInterventions", fields: [sourceTripAnomalyId], references: [id], onDelete: SetNull)
  type        MaintenanceType
  date        DateTime
  km          Int
  costEur     Decimal?        @db.Decimal(10, 2)
  garage      String?
  description String
  notes       String?
  createdAt   DateTime        @default(now())

  @@index([vehicleId, date])
  @@index([sourceTripAnomalyId])
}

model Deadline {
  id            String       @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  sourceDocumentId String?
  sourceDocument Document?   @relation("DocumentGeneratedDeadlines", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  type          DeadlineType
  dueDate       DateTime
  dueKm         Int?
  reminderDays  Int          @default(30)
  description   String?
  completed     Boolean      @default(false)
  completedDate DateTime?
  autoGenerated Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  plannedMaintenances PlannedMaintenance[] @relation("DeadlinePlannedMaintenances")

  @@index([vehicleId])
  @@index([sourceDocumentId])
  @@index([dueDate])
  @@index([completed, dueDate])
}

model Document {
  id               String       @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripAnomalyId    String?
  tripAnomaly      TripAnomaly? @relation(fields: [tripAnomalyId], references: [id], onDelete: SetNull)
  uploadedByUserId String
  uploadedBy       User         @relation(fields: [uploadedByUserId], references: [id])
  type             DocumentType
  name             String
  filePath         String
  mimeType         String
  sizeBytes        Int
  notes            String?
  validFrom        DateTime?
  validTo          DateTime?
  createdAt        DateTime     @default(now())

  generatedDeadlines Deadline[] @relation("DocumentGeneratedDeadlines")

  @@index([vehicleId])
  @@index([type])
  @@index([tripAnomalyId])
}

enum PlannedMaintenanceStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

model PlannedMaintenance {
  id          String                   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User                     @relation(fields: [createdById], references: [id])
  sourceDeadlineId String?
  sourceDeadline   Deadline?           @relation("DeadlinePlannedMaintenances", fields: [sourceDeadlineId], references: [id], onDelete: SetNull)
  sourceTripAnomalyId String?
  sourceTripAnomaly   TripAnomaly?     @relation("TripAnomalyPlannedMaintenances", fields: [sourceTripAnomalyId], references: [id], onDelete: SetNull)
  type        MaintenanceType
  scheduledDate DateTime
  description String
  garage      String?
  notes       String?
  status      PlannedMaintenanceStatus @default(PLANNED)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([vehicleId])
  @@index([sourceDeadlineId])
  @@index([sourceTripAnomalyId])
  @@index([scheduledDate])
  @@index([status, scheduledDate])
}

model Trip {
  id         String     @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId   String
  driver     User       @relation(fields: [driverId], references: [id])
  status     TripStatus @default(OPEN)
  startTime  DateTime
  endTime    DateTime?
  startKm    Int
  endKm      Int?
  startQrRaw String
  endQrRaw   String?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  anomalies TripAnomaly[]

  @@index([vehicleId, startTime])
  @@index([driverId, startTime])
  @@index([status, startTime])
}

model TripAnomaly {
  id               String            @id @default(cuid())
  tripId           String
  trip             Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type             TripAnomalyType
  status           TripAnomalyStatus @default(OPEN)
  message          String
  isManual         Boolean           @default(false)
  createdByUserId  String
  createdBy        User              @relation("TripAnomalyCreatedBy", fields: [createdByUserId], references: [id])
  resolvedByUserId String?
  resolvedBy       User?             @relation("TripAnomalyResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolutionNotes  String?
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())

  photos           Document[]
  plannedMaintenances      PlannedMaintenance[]      @relation("TripAnomalyPlannedMaintenances")
  maintenanceInterventions MaintenanceIntervention[] @relation("TripAnomalyMaintenanceInterventions")

  @@index([tripId])
  @@index([type, createdAt])
  @@index([status, createdAt])
  @@index([resolvedByUserId])
}

model VehiclePhoto {
  id               String                 @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  template         VehiclePhotoTemplate
  filePath         String
  uploadedByUserId String
  uploadedBy       User                   @relation(fields: [uploadedByUserId], references: [id])
  uploadedAt       DateTime               @default(now())
  createdAt        DateTime               @default(now())
  deletedAt        DateTime?

  @@unique([vehicleId, template, deletedAt])
  @@index([vehicleId])
  @@index([template])
  @@index([uploadedByUserId])
  @@index([deletedAt])
}
