generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
}

enum OwnershipType {
  OWNED
  RENTED
  LEASED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum FuelType {
  DIESEL
  GASOLINE
  ELECTRIC
  HYBRID
  LPG
  CNG
}

enum MileageSource {
  MANUAL
  REFUEL
  MAINTENANCE
}

enum MaintenanceType {
  TAGLIANDO
  REVISIONE
  RIPARAZIONE
  CAMBIO_GOMME
  ALTRO
}

enum DeadlineType {
  TAGLIANDO
  REVISIONE
  ASSICURAZIONE
  BOLLO
  REVISIONE_TACHIGRAFO
  ALTRO
}

enum DocumentType {
  CONTRATTO_NOLEGGIO
  ASSICURAZIONE
  LIBRETTO
  CARTA_CIRCOLAZIONE
  ALTRO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(DRIVER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedVehicles         Vehicle[]
  mileageReadings          MileageReading[]
  refuelings               Refueling[]
  maintenanceInterventions MaintenanceIntervention[]
  uploadedDocuments        Document[]
  plannedMaintenances      PlannedMaintenance[]
}

model Vehicle {
  id               String        @id @default(cuid())
  plate            String        @unique
  brand            String
  model            String
  year             Int
  vin              String?
  fuelType         FuelType
  ownershipType              OwnershipType
  status                     VehicleStatus @default(ACTIVE)
  registrationDate           DateTime?
  maintenanceIntervalMonths  Int?          @default(12)
  maintenanceIntervalKm      Int?
  assignedDriverId           String?
  assignedDriver             User?         @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  notes                      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  mileageReadings          MileageReading[]
  refuelings               Refueling[]
  maintenanceInterventions MaintenanceIntervention[]
  deadlines                Deadline[]
  documents                Document[]
  plannedMaintenances      PlannedMaintenance[]

  @@index([plate])
  @@index([status])
  @@index([assignedDriverId])
}

model MileageReading {
  id               String        @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  recordedByUserId String
  recordedBy       User          @relation(fields: [recordedByUserId], references: [id])
  km               Int
  date             DateTime
  source           MileageSource
  notes            String?
  createdAt        DateTime      @default(now())

  @@index([vehicleId, date])
  @@index([vehicleId, km])
}

model Refueling {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  km        Int
  liters    Decimal  @db.Decimal(10, 2)
  costEur   Decimal  @db.Decimal(10, 2)
  fuelType  FuelType
  fullTank  Boolean  @default(true)
  station   String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([vehicleId, date])
}

model MaintenanceIntervention {
  id          String          @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        MaintenanceType
  date        DateTime
  km          Int
  costEur     Decimal?        @db.Decimal(10, 2)
  garage      String?
  description String
  notes       String?
  createdAt   DateTime        @default(now())

  @@index([vehicleId, date])
}

model Deadline {
  id            String       @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type          DeadlineType
  dueDate       DateTime
  dueKm         Int?
  reminderDays  Int          @default(30)
  description   String?
  completed     Boolean      @default(false)
  completedDate DateTime?
  autoGenerated Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([vehicleId])
  @@index([dueDate])
  @@index([completed, dueDate])
}

model Document {
  id               String       @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  uploadedByUserId String
  uploadedBy       User         @relation(fields: [uploadedByUserId], references: [id])
  type             DocumentType
  name             String
  filePath         String
  mimeType         String
  sizeBytes        Int
  notes            String?
  createdAt        DateTime     @default(now())

  @@index([vehicleId])
  @@index([type])
}

enum PlannedMaintenanceStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

model PlannedMaintenance {
  id          String                   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User                     @relation(fields: [createdById], references: [id])
  type        MaintenanceType
  scheduledDate DateTime
  description String
  garage      String?
  notes       String?
  status      PlannedMaintenanceStatus @default(PLANNED)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([vehicleId])
  @@index([scheduledDate])
  @@index([status, scheduledDate])
}
